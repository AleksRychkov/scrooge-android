-- Table
CREATE TABLE IF NOT EXISTS Tag (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  name TEXT NOT NULL UNIQUE,
  colorHex TEXT
);

-- Queries
selectAll:
SELECT * FROM Tag;

selectByName:
SELECT * FROM Tag WHERE name = ? LIMIT 1;

create:
INSERT INTO Tag (name, colorHex) VALUES (?, ?);

delete:
DELETE FROM Tag WHERE id = ?;
