<resources xmlns:tools="http://schemas.android.com/tools">


    <!-- Allows us to override night specific attributes in the
        values-night folder. -->
    <style name="NightAdjusted.Theme.Scrooge" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- The final theme we use -->
    <style name="Theme.Scrooge" parent="NightAdjusted.Theme.Scrooge">
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="NightAdjusted.Theme.Splash" parent="Theme.SplashScreen">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.Scrooge.Splash" parent="NightAdjusted.Theme.Splash">
        <item name="windowSplashScreenBackground">@color/windowBg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Scrooge</item>
    </style>
</resources>