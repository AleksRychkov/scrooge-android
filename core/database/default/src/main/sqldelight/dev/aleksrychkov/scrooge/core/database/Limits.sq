-- Tables
CREATE TABLE IF NOT EXISTS Limits (
    id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
    amount INTEGER NOT NULL,
    type INTEGER NOT NULL,
    currencyCode TEXT NOT NULL
);

-- Queries
selectAll:
SELECT * FROM Limits;

create:
INSERT INTO Limits (amount, type, currencyCode) VALUES (?, ?, ?);

update:
UPDATE Limits SET amount = :amount, type = :type, currencyCode = :currencyCode WHERE id = ?;

delete:
DELETE FROM Limits WHERE id = ?;

getByMinAmount:
SELECT l1.id, l1.amount, l1.type, l1.currencyCode
FROM Limits l1
JOIN (
    SELECT type, currencyCode, MIN(amount) AS minAmount
    FROM Limits
    GROUP BY type, currencyCode
) grouped
ON l1.type = grouped.type
AND l1.currencyCode = grouped.currencyCode
AND l1.amount = grouped.minAmount
ORDER BY l1.currencyCode, l1.type;

getLimitData:
SELECT sum(t.amount) AS total
FROM TTransaction t
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
  AND t.currencyCode = :currencyCode
  AND t.type = 1;