-- Queries
totalAmount:
SELECT
  t.type,
  t.currencyCode,
  sum(t.amount)
FROM TTransaction t
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
  AND (
          NOT EXISTS (SELECT 1 FROM FilterTag)
          OR EXISTS (
            SELECT 1
            FROM TransactionTag tt2
            JOIN FilterTag ft ON ft.tagId = tt2.tagId
            WHERE tt2.transactionId = t.id
          )
      )
  AND (:categoryId IS NULL OR t.categoryId = :categoryId)
  AND (:transactionType IS NULL OR t.type = :transactionType)
GROUP BY t.type, t.currencyCode;

totalAmountMothly:
WITH monthly AS (
    SELECT
      ((t.datestamp / 100) % 100) AS month,
      (t.datestamp / 10000) AS year,
      type,
      t.currencyCode,
      SUM(t.amount) AS total_amount
    FROM TTransaction t
    WHERE
      t.datestamp >= :fromDatestamp
      AND t.datestamp <= :toDatestamp
      AND (
              NOT EXISTS (SELECT 1 FROM FilterTag)
              OR EXISTS (
                SELECT 1
                FROM TransactionTag tt2
                JOIN FilterTag ft ON ft.tagId = tt2.tagId
                WHERE tt2.transactionId = t.id
              )
          )
      AND (:categoryId IS NULL OR t.categoryId = :categoryId)
      AND (:transactionType IS NULL OR t.type = :transactionType)
    GROUP BY year, month, t.type, t.currencyCode
)
SELECT * FROM monthly;

byCategory:
SELECT
  t.type,
  t.currencyCode,
  SUM(t.amount) AS total,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor
FROM TTransaction t
LEFT JOIN Category ON t.categoryId = Category.id
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
  AND (
          NOT EXISTS (SELECT 1 FROM FilterTag)
          OR EXISTS (
            SELECT 1
            FROM TransactionTag tt2
            JOIN FilterTag ft ON ft.tagId = tt2.tagId
            WHERE tt2.transactionId = t.id
          )
      )
  AND (:categoryId IS NULL OR t.categoryId = :categoryId)
  AND (:transactionType IS NULL OR t.type = :transactionType)
GROUP BY t.type, t.currencyCode, t.categoryId;
