-- Queries
totalAmount:
SELECT
	type,
	currencyCode,
	sum(amount)
FROM TTransaction
WHERE timestamp >= ? AND timestamp <= ?
GROUP BY type, currencyCode;

totalAmountMothly:
WITH monthly AS (
    SELECT
        strftime('%m', timestamp/1000, 'unixepoch') AS ym,
        type,
        currencyCode,
        SUM(amount) AS total_amount
    FROM TTransaction
    WHERE strftime('%Y', timestamp/1000, 'unixepoch') = ?
    GROUP BY ym, type, currencyCode
)
SELECT * FROM monthly;

byCategory:
SELECT
	TTransaction.type,
	TTransaction.currencyCode,
	TTransaction.category,
	SUM(TTransaction.amount) AS total,
	Category.id AS categoryId,
    Category.name AS categoryName,
    Category.iconId AS categoryIconId,
    Category.type AS categoryType,
    Category.color AS categoryColor
FROM TTransaction
LEFT JOIN Category ON TTransaction.category = Category.name
WHERE TTransaction.`timestamp` >= ? AND TTransaction.`timestamp` <= ?
GROUP BY TTransaction.type, TTransaction.currencyCode, TTransaction.category;
