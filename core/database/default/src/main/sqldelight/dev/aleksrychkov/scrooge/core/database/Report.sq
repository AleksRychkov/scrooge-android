-- Queries
totalAmount:
SELECT
  t.type,
  t.currencyCode,
  sum(t.amount)
FROM TTransaction t
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
  AND (
        :tagIds = ''
          OR EXISTS (
            SELECT 1
            FROM TransactionTag tt2
            WHERE tt2.transactionId = t.id
              AND instr(
                    '!' || :tagIds || '!',
                    '!' || CAST(tt2.tagId AS TEXT) || '!'
                  ) > 0
          )
      )
GROUP BY t.type, t.currencyCode;

totalAmountMothly:
WITH monthly AS (
    SELECT
      ((t.datestamp / 100) % 100) AS month,
      (t.datestamp / 10000) AS year,
      type,
      t.currencyCode,
      SUM(t.amount) AS total_amount
    FROM TTransaction t
    WHERE
      t.datestamp >= :fromDatestamp
      AND t.datestamp <= :toDatestamp
      AND (
            :tagIds = ''
              OR EXISTS (
                SELECT 1
                FROM TransactionTag tt2
                WHERE tt2.transactionId = t.id
                  AND instr(
                        '!' || :tagIds || '!',
                        '!' || CAST(tt2.tagId AS TEXT) || '!'
                      ) > 0
              )
          )
    GROUP BY year, month, t.type, t.currencyCode
)
SELECT * FROM monthly;

byCategory:
SELECT
  t.type,
  t.currencyCode,
  t.category,
  SUM(t.amount) AS total,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor
FROM TTransaction t
LEFT JOIN Category ON t.category = Category.name
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
  AND (
        :tagIds = ''
          OR EXISTS (
            SELECT 1
            FROM TransactionTag tt2
            WHERE tt2.transactionId = t.id
              AND instr(
                    '!' || :tagIds || '!',
                    '!' || CAST(tt2.tagId AS TEXT) || '!'
                  ) > 0
          )
      )
GROUP BY t.type, t.currencyCode, t.category;
