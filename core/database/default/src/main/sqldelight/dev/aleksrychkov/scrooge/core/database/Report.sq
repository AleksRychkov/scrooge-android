-- Queries
totalAmount:
SELECT
	type,
	currencyCode,
	sum(amount)
FROM TTransaction
WHERE timestamp >= ? AND timestamp <= ?
GROUP BY type, currencyCode;

totalAmountMothly:
WITH monthly AS (
    SELECT
        strftime('%m', timestamp/1000, 'unixepoch') AS ym,
        type,
        currencyCode,
        SUM(amount) AS total_amount
    FROM TTransaction
    WHERE strftime('%Y', timestamp/1000, 'unixepoch') = ?
    GROUP BY ym, type, currencyCode
)
SELECT * FROM monthly;

totalByCategory:
SELECT
	TTransaction.type,
	currencyCode,
	SUM(amount) AS total,
	name AS categoryName,
	iconId AS categoryIconId
FROM TTransaction
LEFT JOIN Category ON category = name
WHERE timestamp >= ? AND timestamp <= ?
GROUP BY TTransaction.type, currencyCode, category;
