-- Table
CREATE TABLE IF NOT EXISTS TTransaction (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  amount INTEGER NOT NULL,
  datestamp INTEGER NOT NULL,
  type INTEGER NOT NULL,
  categoryId INTEGER NOT NULL,
  currencyCode TEXT NOT NULL,
  comment TEXT
);

-- Indexes
CREATE INDEX idx_transaction_datestamp_id ON TTransaction(datestamp DESC, id DESC);
CREATE INDEX idx_transaction_datestamp_type_currency ON TTransaction(datestamp, type, currencyCode);
CREATE INDEX idx_transaction_datestamp_category_type_currency ON TTransaction(datestamp, categoryId, type, currencyCode);

-- Queries
selectFromTo:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.type,
  t.currencyCode,
  t.comment,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor,
  GROUP_CONCAT(tag.name, '!') AS tags,
  GROUP_CONCAT(tag.id, '!') AS tagIds
FROM TTransaction t
LEFT JOIN Category ON t.categoryId = Category.id
LEFT JOIN TransactionTag tt ON t.id = tt.transactionId
LEFT JOIN Tag tag ON tt.tagId = tag.id
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
  AND (
        NOT EXISTS (SELECT 1 FROM FilterTag)
        OR EXISTS (
          SELECT 1
          FROM TransactionTag tt2
          JOIN FilterTag ft ON ft.tagId = tt2.tagId
          WHERE tt2.transactionId = t.id
        )
    )
  AND (:categoryId IS NULL OR t.categoryId = :categoryId)
  AND (:transactionType IS NULL OR t.type = :transactionType)
GROUP BY t.id
ORDER BY t.datestamp DESC, t.id DESC;

selectFromToForExport:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.type,
  t.currencyCode,
  t.categoryId,
  t.comment
FROM TTransaction t
WHERE
  t.datestamp >= :fromDatestamp
  AND t.datestamp <= :toDatestamp
ORDER BY t.datestamp DESC, t.id DESC;

selectFromToKeydBoundaries:
SELECT DISTINCT datestamp
FROM (
  SELECT t.datestamp AS datestamp FROM TTransaction t
  UNION ALL
  SELECT :fromDatestamp AS datestamp
  UNION ALL
  SELECT :toDatestamp AS datestamp
)
WHERE datestamp >= :fromDatestamp
  AND datestamp <= :toDatestamp
ORDER BY datestamp DESC;

selectFromToKeyd:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.type,
  t.currencyCode,
  t.comment,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor,
  GROUP_CONCAT(tag.name, '!') AS tags,
  GROUP_CONCAT(tag.id, '!') AS tagIds
FROM TTransaction t
LEFT JOIN Category ON t.categoryId = Category.id
LEFT JOIN TransactionTag tt ON t.id = tt.transactionId
LEFT JOIN Tag tag ON tt.tagId = tag.id
WHERE
  t.datestamp <= :fromDatestamp
  AND t.datestamp > :toDatestamp
  AND (
      NOT EXISTS (SELECT 1 FROM FilterTag)
      OR EXISTS (
        SELECT 1
        FROM TransactionTag tt2
        JOIN FilterTag ft ON ft.tagId = tt2.tagId
        WHERE tt2.transactionId = t.id
      )
  )
  AND (:categoryId IS NULL OR t.categoryId = :categoryId)
  AND (:transactionType IS NULL OR t.type = :transactionType)
  AND (:currencyCode IS NULL OR t.currencyCode = :currencyCode)
GROUP BY t.id
ORDER BY t.datestamp DESC, t.id DESC;

getLastInsertId:
SELECT last_insert_rowid();

create:
INSERT INTO TTransaction (amount, datestamp, type, categoryId, currencyCode, comment) VALUES (?, ?, ?,  ?, ?, ?);

add:
INSERT INTO TTransaction (id, amount, datestamp, type, categoryId, currencyCode, comment) VALUES (?, ?, ?, ?,  ?, ?, ?);

update:
UPDATE TTransaction SET amount = :amount, datestamp = :datestamp, type = :type, categoryId = :categoryId, currencyCode = :currencyCode, comment = :comment WHERE id = ?;

selectById:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.type,
  t.currencyCode,
  t.comment,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor,
  GROUP_CONCAT(tag.name, '!') AS tags,
  GROUP_CONCAT(tag.id, '!') AS tagIds
FROM TTransaction t
LEFT JOIN Category ON t.categoryId = Category.id
LEFT JOIN TransactionTag tt ON t.id = tt.transactionId
LEFT JOIN Tag tag ON tt.tagId = tag.id
WHERE t.id = ?
GROUP BY t.id;

delete:
DELETE FROM TTransaction WHERE id = ?;

minMaxDatestamp:
SELECT
    min(datestamp) AS minDatestamp,
    max(datestamp) AS maxDatestamp
FROM TTransaction;
