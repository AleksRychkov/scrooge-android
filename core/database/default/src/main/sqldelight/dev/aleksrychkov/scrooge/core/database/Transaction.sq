-- Table
CREATE TABLE IF NOT EXISTS TTransaction (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  amount INTEGER NOT NULL,
  datestamp INTEGER NOT NULL,
  type INTEGER NOT NULL,
  category TEXT NOT NULL,
  tags TEXT,
  currencyCode TEXT NOT NULL
);

-- Queries
selectFromTo:
SELECT
  TTransaction.id,
  TTransaction.amount,
  TTransaction.datestamp,
  TTransaction.category,
  TTransaction.tags,
  TTransaction.type,
  TTransaction.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor
FROM TTransaction
LEFT JOIN Category ON TTransaction.category = Category.name
WHERE TTransaction.datestamp >= :fromDatestamp AND TTransaction.datestamp <= :toDatestamp AND (:tags IS NULL OR TTransaction.tags LIKE :tags)
ORDER BY TTransaction.datestamp DESC, TTransaction.id DESC;

create:
INSERT INTO TTransaction (amount, datestamp, type, category, tags, currencyCode) VALUES (?, ?, ?,  ?, ?, ?);

update:
UPDATE TTransaction SET amount = ?, datestamp = ?, type = ?, category = ?, tags = ?, currencyCode = ? WHERE id = ?;

selectById:
SELECT
  TTransaction.id,
  TTransaction.amount,
  TTransaction.datestamp,
  TTransaction.category,
  TTransaction.tags,
  TTransaction.type,
  TTransaction.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor
FROM TTransaction
LEFT JOIN Category ON TTransaction.category = Category.name
WHERE TTransaction.id = ?;

delete:
DELETE FROM TTransaction WHERE id = ?;

minMaxDatestamp:
SELECT
    min(datestamp) AS minDatestamp,
    max(datestamp) AS maxDatestamp
FROM TTransaction;

allTags:
SELECT DISTINCT TTransaction.tags FROM TTransaction;