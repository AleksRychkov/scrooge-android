-- Table
CREATE TABLE IF NOT EXISTS TTransaction (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  amount INTEGER NOT NULL,
  timestamp INTEGER NOT NULL,
  type INTEGER NOT NULL,
  category TEXT NOT NULL,
  tags TEXT,
  currencyCode TEXT NOT NULL
);

-- Queries
selectFromTo:
SELECT
  TTransaction.id,
  TTransaction.amount,
  TTransaction.`timestamp`,
  TTransaction.category,
  TTransaction.tags,
  TTransaction.type,
  TTransaction.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor
FROM TTransaction
LEFT JOIN Category ON TTransaction.category = Category.name
WHERE TTransaction.`timestamp` >= ? AND TTransaction.`timestamp` <= ?
ORDER BY TTransaction.`timestamp` DESC;

create:
INSERT INTO TTransaction (amount, timestamp, type, category, tags, currencyCode) VALUES (?, ?, ?,  ?, ?, ?);

update:
UPDATE TTransaction SET amount = ?, timestamp = ?, type = ?, category = ?, tags = ?, currencyCode = ? WHERE id = ?;

selectById:
SELECT
  TTransaction.id,
  TTransaction.amount,
  TTransaction.`timestamp`,
  TTransaction.category,
  TTransaction.tags,
  TTransaction.type,
  TTransaction.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor
FROM TTransaction
LEFT JOIN Category ON TTransaction.category = Category.name
WHERE TTransaction.id = ?;

delete:
DELETE FROM TTransaction WHERE id = ?;

minMaxTimestamp:
SELECT
    min(timestamp) AS minTimestamp,
    max(timestamp) AS maxTimestamp
FROM TTransaction;