-- Table
CREATE TABLE IF NOT EXISTS TTransaction (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  amount INTEGER NOT NULL,
  datestamp INTEGER NOT NULL,
  type INTEGER NOT NULL,
  category TEXT NOT NULL,
  currencyCode TEXT NOT NULL
);

-- Indexes
CREATE INDEX idx_transaction_datestamp_id
ON TTransaction(datestamp DESC, id DESC);

CREATE INDEX idx_transaction_datestamp_type_currency
ON TTransaction(datestamp, type, currencyCode);

CREATE INDEX idx_transaction_category_type_currency
ON TTransaction(category, type, currencyCode);

CREATE INDEX idx_transaction_category
ON TTransaction(category);

-- Queries
selectFromTo:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.category,
  t.type,
  t.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor,
  GROUP_CONCAT(tag.name, '!') AS tags,
  GROUP_CONCAT(tag.id, '!') AS tagIds
FROM TTransaction t
LEFT JOIN Category ON t.category = Category.name
LEFT JOIN TransactionTag tt ON t.id = tt.transactionId
LEFT JOIN Tag tag ON tt.tagId = tag.id
WHERE t.datestamp >= :fromDatestamp AND t.datestamp <= :toDatestamp
GROUP BY t.id
ORDER BY t.datestamp DESC, t.id DESC;

selectFromToKeydBoundaries:
SELECT
  DISTINCT TTransaction.datestamp
FROM TTransaction
WHERE TTransaction.datestamp >= :fromDatestamp AND TTransaction.datestamp <= :toDatestamp
ORDER BY TTransaction.datestamp DESC;

selectFromToKeyd:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.category,
  t.type,
  t.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor,
  GROUP_CONCAT(tag.name, '!') AS tags,
  GROUP_CONCAT(tag.id, '!') AS tagIds
FROM TTransaction t
LEFT JOIN Category ON t.category = Category.name
LEFT JOIN TransactionTag tt ON t.id = tt.transactionId
LEFT JOIN Tag tag ON tt.tagId = tag.id
WHERE t.datestamp <= :fromDatestamp AND t.datestamp > :toDatestamp
GROUP BY t.id
ORDER BY t.datestamp DESC, t.id DESC;

create:
INSERT INTO TTransaction (amount, datestamp, type, category, currencyCode) VALUES (?, ?, ?,  ?, ?);

update:
UPDATE TTransaction SET amount = ?, datestamp = ?, type = ?, category = ?, currencyCode = ? WHERE id = ?;

selectById:
SELECT
  t.id,
  t.amount,
  t.datestamp,
  t.category,
  t.type,
  t.currencyCode,
  Category.id AS categoryId,
  Category.name AS categoryName,
  Category.iconId AS categoryIconId,
  Category.type AS categoryType,
  Category.color AS categoryColor,
  GROUP_CONCAT(tag.name, '!') AS tags,
  GROUP_CONCAT(tag.id, '!') AS tagIds
FROM TTransaction t
LEFT JOIN Category ON t.category = Category.name
LEFT JOIN TransactionTag tt ON t.id = tt.transactionId
LEFT JOIN Tag tag ON tt.tagId = tag.id
WHERE t.id = ?
GROUP BY t.id;

delete:
DELETE FROM TTransaction WHERE id = ?;

minMaxDatestamp:
SELECT
    min(datestamp) AS minDatestamp,
    max(datestamp) AS maxDatestamp
FROM TTransaction;
