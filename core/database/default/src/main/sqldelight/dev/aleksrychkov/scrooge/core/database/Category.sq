-- Table
CREATE TABLE IF NOT EXISTS Category (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  name TEXT NOT NULL UNIQUE,
  type INTEGER NOT NULL,
  iconId TEXT NOT NULL,
  color INTEGER NOT NULL
);

-- Indexes
CREATE INDEX idx_category_type ON Category(type);
CREATE INDEX idx_category_name_type ON Category(name, type);

-- Queries
getById:
SELECT * FROM Category WHERE id = :id LIMIT 1;

selectAllByType:
SELECT * FROM Category WHERE type = :type;

create:
INSERT INTO Category (name, type, iconId, color) VALUES (?, ?, ?, ?);

update:
UPDATE Category SET name = :name, type = :type, iconId = :iconId, color = :color WHERE id = :id;

getByNameAndType:
SELECT * FROM Category WHERE name = :name AND type = :type;

delete:
DELETE FROM Category WHERE id = :id;
