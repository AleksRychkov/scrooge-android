-- Table
CREATE TABLE IF NOT EXISTS Category (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  name TEXT NOT NULL UNIQUE,
  type INTEGER NOT NULL,
  iconId TEXT NOT NULL,
  color INTEGER NOT NULL,
  orderIndex INTEGER NOT NULL
);

-- Indexes
CREATE INDEX idx_category_type ON Category(type);
CREATE INDEX idx_category_name_type ON Category(name, type);

-- Queries
getById:
SELECT * FROM Category WHERE id = :id LIMIT 1;

getByOrderIndex:
SELECT * FROM Category WHERE orderIndex = :orderIndex AND type = :type LIMIT 1;

selectAllByType:
SELECT * FROM Category WHERE type = :type ORDER BY orderIndex ASC;

create:
INSERT INTO Category (name, type, iconId, color, orderIndex) VALUES (?, ?, ?, ?, ?);

add:
INSERT INTO Category (id, name, type, iconId, color, orderIndex) VALUES (?, ?, ?, ?, ?, ?);

update:
UPDATE Category SET name = :name, type = :type, iconId = :iconId, color = :color WHERE id = :id;

getByNameAndType:
SELECT * FROM Category WHERE name = :name AND type = :type ORDER BY orderIndex ASC;

delete:
DELETE FROM Category WHERE id = :id;

lastOrderIndex:
SELECT orderIndex FROM Category WHERE type = :type ORDER BY orderIndex DESC LIMIT 1;

updateIndexingAfterDelete:
UPDATE Category SET orderIndex = orderIndex - 1 WHERE type = :type AND orderIndex > :deletedOrderIndex;

setOrderIndex:
UPDATE Category SET orderIndex = :orderIndex WHERE id = :id;

selectAll:
SELECT * FROM Category;
