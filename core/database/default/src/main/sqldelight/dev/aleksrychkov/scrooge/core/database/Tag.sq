-- Tables
CREATE TABLE IF NOT EXISTS Tag (
  id INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  name TEXT NOT NULL UNIQUE
);

CREATE TABLE IF NOT EXISTS TransactionTag (
  transactionId INTEGER NOT NULL,
  tagId INTEGER NOT NULL,
  PRIMARY KEY (transactionId, tagId),
  FOREIGN KEY (transactionId) REFERENCES TTransaction(id) ON DELETE CASCADE,
  FOREIGN KEY (tagId) REFERENCES Tag(id) ON DELETE CASCADE
);

-- Indexes
CREATE INDEX idx_tag_name ON Tag(name);
CREATE INDEX idx_tag_id ON Tag(id);

-- Queries
selectAll:
SELECT * FROM Tag;

selectByName:
SELECT * FROM Tag WHERE name = ? LIMIT 1;

create:
INSERT INTO Tag (name) VALUES (?);

delete:
DELETE FROM Tag WHERE id = ?;

createTransactioTag:
INSERT INTO TransactionTag (transactionId, tagId) VALUES (:transactionId, :tagId);

deleteTransactioTag:
DELETE FROM TransactionTag WHERE transactionId = :transactionId;
